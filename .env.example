# ── Shared env (copy to .env in each package as needed) ──────────────────────
# Stellar network
NETWORK=testnet
RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Browser-safe passkey smart wallet configuration (frontend only; never place private keys here)
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_SMART_WALLET_WASM_HASH=
NEXT_PUBLIC_CLIENT_ERROR_ENDPOINT= # optional, server-side telemetry collector

# On-chain contracts & assets (isi setelah deploy — dari tim contract)
USDC_SAC=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
ESCROW_ID=CC7HMK6K2LYJLMXT5BLVXLJOUWZREAXTL7SRSWFS5TSOA3PZQSVJM6R7  # verified: https://stellar.expert/explorer/testnet/contract/CC7HMK6K2LYJLMXT5BLVXLJOUWZREAXTL7SRSWFS5TSOA3PZQSVJM6R7
REGISTRY_ID=         # contract id registry/ledger (opsional, layer 2)

# Relayer (backend membayar fee user)
RELAYER_SECRET=      # secret key akun layanan pembayar fee (S...)
SETTLEMENT_SECRET=   # secret key akun settlement yang di-allowlist di escrow (public: GAMJFAOO4R3E6TU3UTT4AH2OZUA2CC7O6LVM2YDRYYIOYNFWAHSKKNOT)

# Anchor (cash-out / off-ramp) — SDF Test Anchor dulu
ANCHOR_SEP10_URL=
ANCHOR_SEP24_URL=
ANCHOR_HOME_DOMAIN=

# Kurs live (REAL) — RM->IDR, HKD->IDR
FX_API_URL=https://open.er-api.com/v6/latest

# OTP (SMS) — sandbox/mock untuk hackathon
OTP_PROVIDER=mock    # mock | twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

# App
DATABASE_URL=file:./dev.db
PUBLIC_BASE_URL=http://localhost:3000

# Auth pengirim (JWT + WebAuthn) — generate acak utk lokal: openssl rand -hex 32
AUTH_JWT_SECRET=
PHONE_HMAC_KEY=
AUTH_RP_ID=localhost              # rpId WebAuthn (domain frontend, tanpa port)
AUTH_ORIGIN=http://localhost:3000 # origin frontend persis

# Frontend (frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_SMART_WALLET_WASM_HASH: hash WASM smart wallet passkey-kit yang ter-install
# di jaringan. Testnet 2026-07: 84924c53a413318df2ce753e30de53ec651404c916d30e861718ad155c94b319
# (build dari kalepail/passkey-kit commit b6c6a60 = npm passkey-kit 0.12.1)

# Otomasi langkah interaktif SEP-24 (khusus reference anchor SDF; opsional override)
ANCHOR_BUSINESS_SERVER_URL=https://anchor-reference-server-testanchor.stellar.org
